{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/router.tsx",
    "src/start.ts",
    "src/worker/index.ts",
    "src/bootstrap.ts",
    "src/composition.ts",
    "scripts/cleanup-kodes.ts",
    "scripts/check-db.ts",
    "scripts/cleanup-all.ts",
    "vite.config.ts",
    "drizzle.config.ts"
  ],
  "ignorePatterns": [
    "src/routeTree.gen.ts",
    "drizzle/**",
    "dist/**",
    "dist-worker/**",
    ".output/**",
    "e2e/**",
    "docs/**",
    ".claude/**",
    "src/shared/testing/**",
    "scripts/**"
  ],
  "ignoreDependencies": [
    "@rolldown/binding-darwin-arm64",
    "@tanstack/intent",
    "@better-auth/cli",
    "@tanstack/start-server-core",
    "eslint-import-resolver-typescript"
  ],
  "ignoreExports": [
    { "file": "src/contexts/*/infrastructure/jobs/*.job.ts", "exports": ["JOB_NAME"] },
    { "file": "src/shared/jobs/*.job.ts", "exports": ["JOB_NAME"] },
    {
      "file": "src/contexts/identity/server/organizations.*.ts",
      "exports": [
        "updateOrganization",
        "finalizeAvatarUpload",
        "finalizeOrgLogoUpload",
        "requestAvatarUpload",
        "requestOrgLogoUpload"
      ]
    },
    {
      "file": "src/contexts/inbox/domain/constructors.ts",
      "exports": ["createInboxItem", "CreateInboxItemInput"]
    },
    {
      "file": "src/contexts/*/infrastructure/adapters/db-user-lookup.adapter.ts",
      "exports": ["createDbUserLookupAdapter"]
    },
    {
      "file": "src/contexts/integration/infrastructure/handlers/gbp-notification-handler.ts",
      "exports": ["handleGbpNotification"]
    },
    {
      "file": "src/shared/db/schema/auth.ts",
      "exports": ["member", "organization"]
    }
  ],
  "production": false,
  "rules": {
    "unresolved-imports": "error",
    "unlisted-dependencies": "error",
    "duplicate-exports": "error",
    "circular-dependencies": "error",
    "unused-files": "warn",
    "unused-dependencies": "warn",
    "unused-dev-dependencies": "warn",
    "unused-exports": "warn",
    "unused-types": "off"
  },
  "duplicates": {
    "mode": "mild",
    "minTokens": 50,
    "minLines": 5,
    "threshold": 10
  },
  "health": {
    "maxCyclomatic": 22,
    "maxCognitive": 15,
    "maxCrap": 450
  },
  "audit": {
    "gate": "new-only"
  },
  "boundaries": {
    "zones": [
      { "name": "domain", "patterns": ["src/contexts/*/domain/**"] },
      { "name": "application", "patterns": ["src/contexts/*/application/**"] },
      { "name": "infrastructure", "patterns": ["src/contexts/*/infrastructure/**"] },
      { "name": "server", "patterns": ["src/contexts/*/server/**"] },
      { "name": "shared-testing", "patterns": ["src/shared/testing/**"] },
      { "name": "shared-events", "patterns": ["src/shared/events/**"] },
      { "name": "shared", "patterns": ["src/shared/**"] },
      { "name": "routes", "patterns": ["src/routes/**"] },
      { "name": "components", "patterns": ["src/components/**"] }
    ],
    "rules": [
      { "from": "domain", "allow": ["shared", "shared-events"] },
      { "from": "application", "allow": ["domain", "shared", "shared-events"] },
      {
        "from": "infrastructure",
        "allow": ["domain", "application", "shared", "shared-events"]
      },
      { "from": "server", "allow": ["application", "domain", "shared", "shared-events"] },
      {
        "from": "shared-testing",
        "allow": ["domain", "application", "shared", "shared-events"]
      },
      { "from": "shared-events", "allow": ["domain", "shared"] },
      { "from": "shared", "allow": ["shared-events"] }
    ]
  },
  "regression": {
    "baseline": {
      "totalIssues": 355,
      "unusedFiles": 24,
      "unusedExports": 204,
      "unusedTypes": 0,
      "unusedDependencies": 0,
      "unusedDevDependencies": 1,
      "unusedOptionalDependencies": 0,
      "unusedEnumMembers": 0,
      "unusedClassMembers": 0,
      "unresolvedImports": 0,
      "unlistedDependencies": 1,
      "duplicateExports": 4,
      "circularDependencies": 0,
      "reExportCycles": 0,
      "typeOnlyDependencies": 0,
      "testOnlyDependencies": 0,
      "boundaryViolations": 0,
      "boundaryCoverageViolations": 0,
      "boundaryCallViolations": 0,
      "policyViolations": 0
    }
  }
}
