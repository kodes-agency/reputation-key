# ── Server ──
NODE_ENV=development
PORT=3000

# ── Database (Neon PostgreSQL) ──
# Create a Neon database at https://neon.new
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL_POOLER=

# ── Auth (Better Auth) ──
# Generate: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET=change-me-to-a-real-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:3000

# ── Redis (optional in dev — health check reports redis: false) ──
REDIS_URL=

# ── Logging ──
LOG_LEVEL=debug