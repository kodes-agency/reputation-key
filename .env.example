# Reputation Key — Environment Configuration
# Copy this file to `.env.local` and fill in your values.
# NEVER commit `.env.local` or `.env` to git.

# ── Server ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database (Neon PostgreSQL) ──────────────────────────────────────
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=
DATABASE_URL_POOLER=          # Optional — pooled connection for serverless

# ── Authentication (Better Auth) ────────────────────────────────────
# Generate with: npx -y @better-auth/cli secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── Email (Resend) ──────────────────────────────────────────────────
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=

# ── Redis (optional in dev, required in production) ─────────────────
# Used for: BullMQ job queues, rate limiting, caching
REDIS_URL=                    # e.g. redis://localhost:6379

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Error Tracking (Sentry — optional) ──────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
