{
  "name": "reputation-key",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "NODE_ENV=development vite dev --port 3000",
    "dev:worker": "tsx src/worker/index.ts",
    "dev:all": "concurrently -n web,worker -c blue,green \"pnpm dev\" \"pnpm dev:worker\"",
    "build": "vite build",
    "build:worker": "tsup",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && node scripts/check-filenames.mjs && node scripts/check-component-boundaries.mjs",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project=unit",
    "test:integration": "vitest run --project=integration",
    "test:watch": "vitest --project=unit",
    "test:e2e": "playwright test",
    "seed": "tsx scripts/seed.ts",
    "seed:simulate": "tsx scripts/seed.ts -- --invariants",
    "simulate": "tsx scripts/simulate.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "auth:generate": "npx -y dotenv-cli -- npx -y @better-auth/cli generate --config src/shared/auth/auth-cli.ts",
    "auth:migrate": "npx -y dotenv-cli -- npx -y @better-auth/cli migrate --config src/shared/auth/auth-cli.ts",
    "db:bootstrap-auth": "npx -y dotenv-cli -- bash -c 'psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/migrations/0000-auth-tables-bootstrap.sql'",
    "db:matviews": "npx -y dotenv-cli -- bash -c 'psql \"$DATABASE_URL\" -v ON_ERROR_STOP=1 -f scripts/migrations/add-materialized-views-and-gbp-index.sql'",
    "audit:member-roles": "tsx scripts/audit-member-roles.ts",
    "audit:auth-schema": "npx -y dotenv-cli -- node scripts/verify-auth-schema.mjs",
    "start": "node .output/server/index.mjs",
    "start:worker": "node dist-worker/index.js",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test:storybook": "VITEST_STORYBOOK=true vitest run --project='storybook:**'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@rolldown/binding-darwin-arm64": "^1.0.1",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "1.170.10",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "1.168.18",
    "better-auth": "^1.6.13",
    "bullmq": "^5.75.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.1",
    "fractional-indexing": "^3.2.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "neverthrow": "^8.2.0",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "3.8.0",
    "resend": "^6.12.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "@aws-sdk/s3-request-presigner": "^3.1039.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "~10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "~10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@storybook/test-runner": "^0.24.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/devtools-vite": "0.7.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.15.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/sharp": "^0.32.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "4.1.10",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "^9.2.4",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "fallow": "^2.97.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nitro": "^3.0.260429-beta",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "shadcn": "^4.10.0",
    "sharp": "^0.34.5",
    "storybook": "^10.4.6",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.16",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "kysely": "0.28.17",
      "hono": "4.12.30",
      "js-yaml": "4.3.0"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "pino"
    ]
  }
}
